                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Reviews"
                ],
                "summary": "Laisser un avis",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
