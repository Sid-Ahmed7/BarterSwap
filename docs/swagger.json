{
    "swagger": "2.0",
    "info": {
        "description": "API REST d'échange de compétences via crédits-temps.",
        "title": "BarterSwap API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/exchanges": {
            "get": {
                "description": "Récupère la liste des demandes d'échanges (en tant que demandeur ou prestataire) pour l'utilisateur connecté, avec filtre par statut optionnel.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Lister mes échanges",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'utilisateur connecté",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Filtrer par statut (pending, accepted, rejected, cancelled, completed)",
                        "name": "status",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/main.Exchange"
                            }
                        }
                    },
                    "400": {
                        "description": "En-tête manquant",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Crée une nouvelle demande d'échange pour un service spécifié. L'utilisateur connecté doit disposer d'assez de crédits.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Créer une demande d'échange",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'utilisateur connecté",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Détails de la demande d'échange",
                        "name": "exchange",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/main.ExchangeRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/main.Exchange"
                        }
                    },
                    "400": {
                        "description": "Requête invalide ou crédits insuffisants",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Service ou demandeur non trouvé",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "409": {
                        "description": "Conflit (échange déjà actif)",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/exchanges/{id}": {
            "get": {
                "description": "Récupère les détails d'un échange par son ID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Obtenir le détail d'un échange",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.Exchange"
                        }
                    },
                    "400": {
                        "description": "ID invalide",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Échange non trouvé",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/exchanges/{id}/accept": {
            "put": {
                "description": "Accepte une demande d'échange en cours. Seul le propriétaire du service peut accepter et cela débite les crédits correspondants au demandeur.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Accepter une demande d'échange",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "ID du propriétaire",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.Exchange"
                        }
                    },
                    "400": {
                        "description": "Requête invalide ou crédits insuffisants",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "403": {
                        "description": "Accès interdit",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Échange non trouvé",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/exchanges/{id}/cancel": {
            "put": {
                "description": "Annule un échange en cours. Le demandeur et le prestataire peuvent tous deux l'annuler. Si l'échange était accepté, le demandeur est remboursé.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Annuler un échange",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "ID de l'utilisateur connecté",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.Exchange"
                        }
                    },
                    "400": {
                        "description": "Statut invalide",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "403": {
                        "description": "Accès interdit",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Échange non trouvé",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/exchanges/{id}/complete": {
            "put": {
                "description": "Termine un échange. Seul le demandeur peut le valider une fois le service rendu, ce qui transfère les crédits au prestataire.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Marquer un échange comme terminé",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "ID du demandeur",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.Exchange"
                        }
                    },
                    "400": {
                        "description": "Statut invalide",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "403": {
                        "description": "Accès interdit",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Échange non trouvé",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/exchanges/{id}/reject": {
            "put": {
                "description": "Refuse une demande d'échange en cours. Seul le propriétaire du service peut la refuser.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Exchanges"
                ],
                "summary": "Refuser une demande d'échange",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID de l'échange",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "ID du propriétaire",
                        "name": "X-User-ID",
                        "in": "header",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
